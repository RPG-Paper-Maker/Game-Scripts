{
  "compilerOptions": {
    "target": "es2020",
    "module": "esNext",
    "moduleResolution": "node",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "noEmit": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "build/Scripts"
  },
  "include": [
    "./src/**/*.ts",
  ],
  "exclude": ["node_modules"],
  "types": ["howler"]
}